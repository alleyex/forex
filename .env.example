# Core runtime
LOG_LEVEL=INFO
BROKER_PROVIDER=ctrader
TOKEN_FILE=token.json

# Logging
# LOG_FILE=runtime/forex.log

# cTrader timeouts
CTRADER_REQUEST_TIMEOUT=10
CTRADER_OAUTH_TIMEOUT=120
CTRADER_OAUTH_LOGIN_TIMEOUT=180

# Retry behavior
CTRADER_RETRY_MAX_ATTEMPTS=0
CTRADER_RETRY_BACKOFF_SECONDS=1

# Metrics
METRICS_LOG_INTERVAL=30
